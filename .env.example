# Copy to .env and fill in real values. Never commit .env.

# ── Core ──────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/treasury
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── XRPL (Testnet) ────────────────────────────────────────────────────────────
XRPL_ENDPOINT=wss://s.altnet.rippletest.net:51233
TREASURY_WALLET_SEED=
TREASURY_WALLET_ADDRESS=
TOKEN_ISSUER_ADDRESS=rQhWct2fv4Vc4KRjRgMrxa8xPN9Zx9iLKV
TOKEN_CURRENCY=RLUSD
USE_MOCK_XRPL=true

# ── Policy ────────────────────────────────────────────────────────────────────
POLICY_THRESHOLD_USD=10000
POLICY_COMPLIANCE_FLAG_SCORE=60

# ── Firefly ───────────────────────────────────────────────────────────────────
FIREFLY_PUBLIC_KEY=
XRPL_NETWORK=xrpl:testnet

# ── ARS Feature flags ─────────────────────────────────────────────────────────
TRADE_FINANCE_ENABLED=true
X402_ENABLED=true
X402_FACILITATOR_URL=https://xrpl-x402.t54.ai
X402_ALLOWED_ASSETS=RLUSD
X402_ALLOWED_FACILITATORS=https://xrpl-x402.t54.ai
DELEGATION_ENABLED=true

# ── XLS-65 Vault (Devnet) ─────────────────────────────────────────────────────
VAULT_ENABLED=true
VAULT_XRPL_ENDPOINT=wss://s.devnet.rippletest.net:51233
VAULT_ID=

# ── XLS-66 Lending (check amendment on Devnet before enabling) ────────────────
LENDING_ENABLED=false
LENDING_XRPL_ENDPOINT=wss://s.devnet.rippletest.net:51233
LENDING_LOAN_BROKER_ADDRESS=

# ── Agent ─────────────────────────────────────────────────────────────────────
AGENT_ENABLED=true
AGENT_SENDER_COUNTRY=CH
DEMO_MODE=false
