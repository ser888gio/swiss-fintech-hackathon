# Copy to .env and fill in real values. Never commit .env.

# ── Core ──────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/treasury
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── XRPL (Testnet) ────────────────────────────────────────────────────────────
XRPL_ENDPOINT=wss://s.altnet.rippletest.net:51233
WALLET_TESTNET_ENDPOINT=wss://s.altnet.rippletest.net:51233
WALLET_DEVNET_ENDPOINT=wss://s.devnet.rippletest.net:51233
TREASURY_WALLET_SEED=
TREASURY_WALLET_ADDRESS=
TOKEN_ISSUER_ADDRESS=rQhWct2fv4Vc4KRjRgMrxa8xPN9Zx9iLKV
TOKEN_CURRENCY=RLUSD
USE_MOCK_XRPL=true

# ── Policy ────────────────────────────────────────────────────────────────────
POLICY_THRESHOLD_USD=500
POLICY_COMPLIANCE_FLAG_SCORE=60

# ── Plaid — AML/IDV screening (Plaid-modelled credential URI) ────────────────
# Monitor: watchlist screening (sanctions/PEP/adverse media). Requires a
# watchlist program created in Plaid Dashboard → Monitor → Programs.
# IDV: identity verification sessions. Requires a template in Plaid Dashboard
# → Identity Verification → Templates.
# Leave all blank to fall back to OpenSanctions + FATF risk model.
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_WATCHLIST_PROGRAM_ID_INDIVIDUAL=
PLAID_WATCHLIST_PROGRAM_ID_ENTITY=
PLAID_IDV_TEMPLATE_ID=

# ── Firefly ───────────────────────────────────────────────────────────────────
FIREFLY_PUBLIC_KEY=
FIREFLY_CONFIRMATION_ENABLED=true
XRPL_NETWORK=xrpl:1

# ── ARS Feature flags ─────────────────────────────────────────────────────────
TRADE_FINANCE_ENABLED=true
X402_ENABLED=true
X402_FACILITATOR_URL=https://xrpl-facilitator-testnet.t54.ai
X402_ALLOWED_ASSETS=RLUSD
X402_ALLOWED_FACILITATORS=https://xrpl-facilitator-testnet.t54.ai
X402_DEMO_PAY_TO=
X402_DEMO_PRICE=1.0
X402_REPAIR_YARD_PAY_TO=
X402_CUSTOMS_PAY_TO=
X402_PORT_AUTHORITY_PAY_TO=
X402_BUNKER_FUEL_PAY_TO=
X402_MARINE_INSURANCE_PAY_TO=
DELEGATION_ENABLED=true

# ── XLS-65 Vault (Devnet) ─────────────────────────────────────────────────────
VAULT_ENABLED=true
VAULT_XRPL_ENDPOINT=wss://s.devnet.rippletest.net:51233
VAULT_ID=

# ── XLS-66 Lending (check amendment on Devnet before enabling) ────────────────
LENDING_ENABLED=false
LENDING_XRPL_ENDPOINT=wss://s.devnet.rippletest.net:51233
LENDING_LOAN_BROKER_ADDRESS=

# ── ARS Insurance — Pillar 3 (pricing & risk engine) ──────────────────────────
# The first-loss pool is backed by the XLS-65 vault above (VAULT_ENABLED).
# Premiums settle as VaultDeposit; payouts draw via VaultWithdraw. Loadings and
# the cover-mandate threshold are tunable here; the rest live in app/insurance/tables.py.
INSURANCE_ENABLED=true
INSURANCE_POOL_FIRST_LOSS_USD=250000
INSURANCE_PREMIUM_CAP_USD=5000
INSURANCE_COVER_REQUIRED_ABOVE_USD=10000
# Optional dedicated Insurance Vault id; empty reuses VAULT_ID / auto-provisions.
INSURANCE_VAULT_ADDRESS=
INSURANCE_SOURCE_TAG=20260530

# ── Agent ─────────────────────────────────────────────────────────────────────
AGENT_ENABLED=true
AGENT_SENDER_COUNTRY=CH
DEMO_MODE=false
