direction: right

browser: Operator Browser {
  class: users
  icon: https://icons.terrastruct.com/essentials%2F359-users.svg
}

railway: Railway Cloud {
  web: Web App (React/Vite) {
    class: nodejs
    icon: https://icons.terrastruct.com/dev%2Freact.svg
  }
  api: API Service (FastAPI) {
    class: python
    icon: https://icons.terrastruct.com/dev%2Fpython.svg
  }
  db: Database (PostgreSQL) {
    class: postgresql
    icon: https://icons.terrastruct.com/dev%2Fpostgresql.svg
  }
}

local: Operator Machine (local) {
  bridge: Firefly Bridge (Node :4747) {
    class: nodejs
    icon: https://icons.terrastruct.com/dev%2Fnodejs.svg
  }
  device: Firefly Pixie (hardware) {
    class: server
    icon: https://icons.terrastruct.com/tech%2F022-server.svg
  }
}

ledger: XRP Ledger (Testnet/Devnet) {
  class: server
  icon: https://icons.terrastruct.com/tech%2F022-server.svg
}
apis: External APIs (OpenAI, Frankfurter, OpenSanctions, t54 x402) {class: cloud}

browser -> railway.web: load dashboard (HTTPS)
browser -> railway.api: payments / release (HTTPS)
browser -> local.bridge: POST /sign (localhost)
railway.api -> railway.db: persist trail
railway.api -> ledger: settle / escrow (WSS)
railway.api -> apis: rates / screen / narrate / x402 {style.stroke-dash: 5}
local.bridge -> local.device: USB serial
local.device -> local.bridge: signature {style.stroke-dash: 5}
