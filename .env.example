# ─────────────────────────────────────────────────────────────
# Copy to .env and fill in. NEVER commit the real .env.
# Wallet seeds and API keys must stay out of git (see .gitignore).
# ─────────────────────────────────────────────────────────────

# --- API (apps/api) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/treasury
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# XRPL — Testnet by default. Switch to Devnet if using XLS-65/66 vaults.
XRPL_ENDPOINT=wss://s.altnet.rippletest.net:51233
TREASURY_WALLET_SEED=s...        # funded testnet wallet (the agent's operating account)
RELEASE_WALLET_SEED=s...         # second key that co-signs/finishes large payments after Firefly verify

# Token settings. If the RLUSD testnet issuer has NOT enabled trust-line
# locking (escrow flag), self-issue a mock USD IOU and set the flag yourself.
TOKEN_ISSUER_ADDRESS=r...
TOKEN_CURRENCY=USD

# Policy thresholds (mirrored as defaults in code; env can override for demos)
POLICY_THRESHOLD_USD=10000
POLICY_COMPLIANCE_FLAG_SCORE=60

# Frankfurter FX (no key required)
FRANKFURTER_BASE_URL=https://api.frankfurter.app

# OpenSanctions screening. Leave the key blank for local demo fallback.
OPENSANCTIONS_API_KEY=
OPENSANCTIONS_BASE_URL=https://api.opensanctions.org
OPENSANCTIONS_DATASET=sanctions
OPENSANCTIONS_MATCH_THRESHOLD=0.85
PUBLIC_INTEL_ENABLED=false

# Browser origins allowed to call the API. Railway can override this with the
# deployed web URL if it changes.
CORS_ORIGINS=http://localhost:5173,http://localhost:4173,https://web-production-cba3.up.railway.app
CORS_ORIGIN_REGEX=https://.*\.up\.railway\.app

# --- Firefly bridge (apps/firefly-bridge, LOCAL ONLY) ---
BRIDGE_PORT=4747
# Public key the backend uses to verify Firefly approval signatures (hex).
FIREFLY_PUBLIC_KEY=

# --- Web (apps/web) ---
# Vite env vars must be prefixed VITE_
VITE_API_BASE_URL=http://localhost:8000
VITE_BRIDGE_BASE_URL=http://localhost:4747
