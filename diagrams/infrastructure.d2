direction: right

operator: Operator Machine {
  browser: Browser Dashboard {
    class: users
    icon: https://icons.terrastruct.com/essentials%2F359-users.svg
  }
  bridge: Firefly Bridge (Node/Express :4747) {
    class: nodejs
    icon: https://icons.terrastruct.com/dev%2Fnodejs.svg
  }
  device: Firefly Pixie (secp256k1 USB) {
    class: server
    icon: https://icons.terrastruct.com/tech%2F022-server.svg
  }
}

railway: Railway Cloud {
  web: Web Service (React/Vite + serve :3000) {
    class: nodejs
    icon: https://icons.terrastruct.com/dev%2Freact.svg
  }
  api: API Service (FastAPI/uvicorn :8000) {
    class: python
    icon: https://icons.terrastruct.com/dev%2Fpython.svg
  }
  db: PostgreSQL (asyncpg) {
    class: postgresql
    icon: https://icons.terrastruct.com/dev%2Fpostgresql.svg
  }
}

external: External Services {
  xrpl: XRP Ledger Testnet/Devnet {
    class: server
    icon: https://icons.terrastruct.com/tech%2F022-server.svg
  }
  openai: OpenAI gpt-4o {class: cloud}
  fx: Frankfurter FX {class: cloud}
  aml: OpenSanctions / Plaid {class: cloud}
  x402: t54 x402 Facilitator {class: cloud}
}

operator.browser -> railway.web: HTTPS (dashboard)
operator.browser -> railway.api: HTTPS / JSON
operator.browser -> operator.bridge: HTTP /sign (localhost)
operator.bridge -> operator.device: USB / serial (button press)

railway.web -> railway.api: REST (inlined base URL)
railway.api -> railway.db: asyncpg (audit trail)
railway.api -> external.xrpl: WebSocket (settle / escrow)
railway.api -> external.openai: HTTPS (narration) {style.stroke-dash: 5}
railway.api -> external.fx: HTTPS (FX rates) {style.stroke-dash: 5}
railway.api -> external.aml: HTTPS (screening) {style.stroke-dash: 5}
railway.api -> external.x402: HTTPS (x402 settle) {style.stroke-dash: 5}
