direction: down

operator: Operator {
  class: users
  icon: https://icons.terrastruct.com/essentials%2F359-users.svg
}

web: Web Dashboard (React/Vite) {
  pages: Pages + Components {
    class: nodejs
    icon: https://icons.terrastruct.com/dev%2Freact.svg
  }
  apilib: lib/api.ts {class: nodejs}
  fireflylib: lib/firefly.ts {class: nodejs}
}

shared: shared types (@treasury/shared) {
  class: nodejs
  icon: https://icons.terrastruct.com/dev%2Ftypescript.svg
}

api: Treasury API (FastAPI) {
  routes: routes (payments, health) {
    class: python
    icon: https://icons.terrastruct.com/dev%2Fpython.svg
  }
  orchestrator: orchestrator {class: python}
  policy: policy/engine.py (DECIDES) {
    class: server
    icon: https://icons.terrastruct.com/tech%2F022-server.svg
  }
  routing: tools/routing {class: python}
  compliance: tools/compliance {class: python}
  execution: tools/execution {class: python}
  fireflytool: tools/firefly (verify sig) {class: python}
  audit: tools/audit (LLM) {class: python}
  store: store / schemas {class: python}
}

db: PostgreSQL {
  class: postgresql
  icon: https://icons.terrastruct.com/dev%2Fpostgresql.svg
}

bridge: Firefly Bridge (Node, local) {
  index: index.ts (:4747) {
    class: nodejs
    icon: https://icons.terrastruct.com/dev%2Fnodejs.svg
  }
  device: device.ts (deriveDigest) {class: nodejs}
}

hw: Firefly Device (USB) {class: server}

xrpl: XRPL testnet {class: cloud}
openai: OpenAI gpt-4o {class: cloud}
frankfurter: Frankfurter FX {class: cloud}
coingecko: CoinGecko {class: cloud}
opensanctions: OpenSanctions {class: cloud}

operator -> web.pages: "uses"
web.apilib -> api.routes: "REST/JSON"
web.fireflylib -> bridge.index: "POST /sign"
web.pages -> shared: "types"
bridge.device -> shared: "types"

api.routes -> api.orchestrator: "process / release"
api.orchestrator -> api.routing: "get FX path"
api.orchestrator -> api.compliance: "screen"
api.orchestrator -> api.policy: "evaluate"
api.orchestrator -> api.audit: "narrate"
api.orchestrator -> api.execution: "settle / escrow / finish"
api.orchestrator -> api.fireflytool: "verify signature"
api.orchestrator -> api.store: "persist trail"
api.store -> db: "asyncpg (staged)"

api.routing -> frankfurter: "fiat rate"
api.routing -> coingecko: "XRP rate"
api.compliance -> opensanctions: "match"
api.audit -> openai: "explain"
api.execution -> xrpl: "Payment / Escrow"

bridge.index -> hw: "USB serial"
hw -> bridge.index: "signature" {style.stroke-dash: 5}
bridge.index -> web.fireflylib: "signature" {style.stroke-dash: 5}
